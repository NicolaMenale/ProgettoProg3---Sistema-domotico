<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml" fx:controller="gui.DecorateSensorController">

    <Label text="Seleziona Sensore"/>

    <ComboBox fx:id="sensorComboBox" prefWidth="200"/>

    <Label text="Moduli disponibili"/>

    <ListView fx:id="moduleListView" prefHeight="150"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Aggiungi Modulo" onAction="#addModule"/>
        <Button text="Chiudi" onAction="#closeWindow"/>
    </HBox>

</VBox>