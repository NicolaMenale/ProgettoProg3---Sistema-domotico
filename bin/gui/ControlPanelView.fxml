<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ControlPanelController">
   <top>
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10;">
        
        <!-- VBox a sinistra con nome + modalità -->
        <VBox alignment="TOP_LEFT" spacing="5">
            <Label fx:id="authorLabel" text="Menale Nicola - Sistema Domotico">
                <font>
                    <Font name="System Bold" size="25" />
                </font>
            </Label>
            <Label fx:id="modeLabel" text="MODALITÀ: COLLAUDO">
                <font>
                    <Font name="System Bold" size="20" />
                </font>
            </Label>
        </VBox>

        <!-- Spacer centrale -->
        <Region HBox.hgrow="ALWAYS" />

        <!-- Bottoni a destra -->
        <Button onAction="#testMode" text="Modalità Collaudo" />
        <Button onAction="#activateMode" text="Modalità Attivato" />
        <Button onAction="#closeApp" text="Esci" />

    </HBox>
</top>
   <center>
      <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0">
         <children>
            <TableView fx:id="statsTableView" layoutY="-1.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
              <columns>
                <TableColumn fx:id="idColumn" text="ID" />
                <TableColumn fx:id="typeColumn" text="Tipo" />
                <TableColumn fx:id="activeColumn" text="Attivo" />
                <TableColumn fx:id="thresholdColumn" text="Soglia" />
                <TableColumn fx:id="moduleColumn" text="Moduli" />
                <TableColumn fx:id="alarmColumn" text="Allarmi" />
                <TableColumn fx:id="readingsColumn" text="Letture" />
                <TableColumn fx:id="alarmHistoryColumn" text="Storico" />
              </columns>
            </TableView>
         </children>
      </AnchorPane>
   </center>
   <bottom>
      <ButtonBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <buttons>
          <Button mnemonicParsing="false" onAction="#openResetWindow" text="Reset" />
            <Button mnemonicParsing="false" onAction="#openInstallPairWindow" text="Nuovo Sensore" />
            <Button mnemonicParsing="false" onAction="#openDecorateWindow" text="Aggiungi Moduli" />
            <Button mnemonicParsing="false" onAction="#simulateCycle" text="Simulazione" />
        </buttons>
      </ButtonBar>
   </bottom>
   <right>
    <VBox prefWidth="300">

        <!-- Log generali -->
        <TextArea fx:id="logArea" wrapText="true" editable="false" promptText="Log sistema" VBox.vgrow="ALWAYS"/>

        <!-- Allarmi in coda -->
        <TextArea fx:id="alarmQueueArea" wrapText="true" editable="false" promptText="Allarmi in coda" VBox.vgrow="ALWAYS"/>

    </VBox>
</right>
</BorderPane>
